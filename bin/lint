#!/usr/bin/env bash
set -e

DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DIR"

# Strict Gleam Linter
#
# Flags patterns that should be intentional, not accidental:
#
#   Pattern          | Why
#   -----------------+--------------------------------------------
#   let assert       | Crashes on mismatch — use Result instead
#   panic            | Crashes unconditionally — handle the error
#   todo             | Placeholder crash — not ready to ship
#   let _ =          | Silently ignored Result — handle or propagate
#   result.unwrap    | Hides errors behind a default value
#   result.lazy_unwrap | Same as above, deferred
#   option.unwrap    | Hides None behind a default value
#   option.lazy_unwrap | Same as above, deferred
#
# Suppress a line by adding a comment on it or an adjacent line:
#
#   // lint:allow <reason>
#
# Runs against src/ only (test code is excluded).

ISSUES=0
TARGET="${1:-src}"

check() {
  local label="$1"
  local pattern="$2"

  local matches=""
  while IFS= read -r hit; do
    [ -z "$hit" ] && continue

    local file line_num
    file="${hit%%:*}"
    line_num="${hit#*:}"
    line_num="${line_num%%:*}"

    # Read a 3-line window (previous, current, next) in one pass
    local window
    window=$(sed -n "$((line_num > 1 ? line_num - 1 : 1)),$((line_num + 1))p" "$file")

    # Skip if any line in the window contains lint:allow
    echo "$window" | grep -q 'lint:allow' && continue

    matches+="$hit"$'\n'
  done < <(grep -rn "$pattern" "$TARGET" --include='*.gleam' 2>/dev/null || true)

  if [ -n "$matches" ]; then
    echo ""
    echo "  $label"
    echo "$matches" | sed '/^$/d; s/^/    /'
    ISSUES=$((ISSUES + 1))
  fi
}

echo "Linting $TARGET/..."

check "let assert (use Result types instead)"             'let assert'
check "panic (handle the error explicitly)"               '\bpanic\b'
check "todo (not ready to ship)"                          '^\s*todo\b\|[({,]\s*todo\b\|\btodo as "'
check "ignored Result (handle or propagate the error)"    'let _ ='
check "result.unwrap (handle the error explicitly)"       'result\.\(lazy_\)\?unwrap'
check "option.unwrap (handle the Option explicitly)"      'option\.\(lazy_\)\?unwrap'

if [ "$ISSUES" -gt 0 ]; then
  echo ""
  echo "Found $ISSUES lint issue(s). Add '// lint:allow <reason>' to suppress."
  exit 1
fi

echo "  No issues found."
